# ===========================================
# Finance Practice Apps - Git Ignore
# ===========================================

# ----- Python -----
**/venv/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env
.env.local
.env.*.local
pip-log.txt

# ----- Node.js -----
**/node_modules/
**/dist/
**/.vite/
*.log
npm-debug.log*

# ----- IDE / Editors -----
.vscode/
.idea/
*.swp
*.swo

# ----- OS Generated -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Copyrighted PDFs -----
*.pdf

# ----- Session data (personal study history) -----
**/Sessions/*.md
**/Sessions/paused/*.json
**/Feedback/*.md

# ----- Temporary files -----
*.tmp
*.temp
*.bak
*~

# ----- Build artifacts -----
build/
dist/
*.egg-info/

# ----- Duplicate finder scripts -----
find_duplicates.py
remove_duplicates.py
